<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- Estructura de navegació Superior -->
    <menuitem name="School" id="menu_root"/>

    <menuitem name="Configuration" id="menu_configuration" parent="menu_root" sequence="99"/>
    

    <!-- GESTIÓ DE CURSOS -->

    <!-- Vista Llista de Cursos-->
    <record model="ir.ui.view" id="school_course_list">
        <field name="name">school.course.list</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <!-- Si volguessim editar la llista, posariem editable="Top" o "Bottom"-->
            <list string="Courses">
                <field name="name"></field>
                <!-- El camp marcat amb invisible no apareix a la vista (per a fer referències)-->
                <field name="hours" invisible="name>'E'"></field>
                <field name="manager_id"></field>
                <field name="thematic_id"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari de Cursos -->
    <record model="ir.ui.view" id="school_course_form">
        <field name="name">school.course.form</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <group col="4">
                        
                        <group colspan="2">
                            <group colspan="2">
                                <field name="name"/>
                                <field name="thematic_id"/>
                                <field name="hours"/>
                            </group>
                            <group colspan="2" col="4" string="MANAGER">
                                <group colspan="1">
                                    </group>
                                <group colspan="3">
                                    <field name="manager_id" string="Teacher"
                                           domain="[('country_id.code','=','ES'),'|',('active','=',True),('active','=',False)]"/>
                                    <field name="manager_phone"/>
                                    <field name="manager_email"/>
                                    <field name="manager_citizenship"/>
                                </group>
                            </group>
                        </group>
                        
                        <group colspan="2">
                            <label for="summary" colspan="2"/>
                            <field name="summary" nolabel="1" colspan="2" widget="html" options="{'resizable':true}"/>
                        </group>
                        
                        <group string="Subjects" colspan="2">
                            <field name="course_subject_ids" nolabel="1" colspan="2" readonly="False">
                                <list editable="top">
                                    <field name="number"/>
                                    <field name="subject_id"/>
                                    <field name="subject_hours"/>
                                </list>
                            </field>
                        </group>
                        
                        <group string="Editions" colspan="2">
                            <field name="edition_ids" nolabel="1" colspan="2" readonly="False">
                                <list>
                                    <field name="name"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </list>
                                <form>
                                    <group>
                                        <group colspan="2">
                                            <field name="name"/>
                                        </group>
                                        <group>
                                            <field name="date_start"/>
                                        </group>
                                        <group>
                                            <field name="date_end"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </group>
                        
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció de Cursos -->
    <record model="ir.actions.act_window" id="school_course_action">
        <field name="name">Courses</field>
        <field name="res_model">school.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu de Cursos -->
    <menuitem name="Courses" id="menu_courses" parent="menu_configuration" action="school_course_action"/>


    <!-- GESTIÓ D'ASSIGNATURES -->
    
    <!-- Vista Llista d'Assignatures -->
    <record model="ir.ui.view" id="school_subject_list">
        <field name="name">school.subject.list</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <list string="Subjects">
                <field name="name"></field>
                <field name="hours"></field>
                <field name="create_uid" optional="show"></field>
                <field name="create_date" optional="show"></field>
                <field name="write_uid" optional="hide"></field>
                <field name="write_date" optional="hide"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari d'Assignatures -->
    <record model="ir.ui.view" id="school_subject_form">
        <field name="name">school.subject.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <!-- "sheet" genera el requadre per al formulari -->
                <sheet>
                    <group col="4">
                        <group colspan="3">
                            <field name="name" placeholder="Introdueixi el nom..."></field>
                        </group>
                        <!-- Sense posar el colspan, ocupa l'espai restant -->
                        <group>
                            <field name="hours" placeholder="???"></field>
                        </group>

                        <!-- Es poden veure els cursos, pero no permetem assignar/crear/eliminar-los -->
                        <group string="Courses" colspan="2" col="2">
                            <!-- Ara apuntem a la classe intermitja SchoolCourseSubject -->
                            <field name="course_subject_ids" nolabel="1" colspan="2">
                                <list>
                                    <field name="number"></field>
                                    <field name="course_id" string="Course"></field>
                                </list>
                            </field>
                        </group>

                        <!-- Es poden veure els professors, pero no permetem assignar/crear/eliminar-los -->
                        <group string="Teachers" colspan="2" col="2">
                            <field name="teacher_ids" nolabel="1" colspan="2">
                                <list>
                                    <field name="first_name"></field>
                                    <field name="last_name"></field>
                                    <field name="phone"></field>
                                    <field name="email" widget="email"></field>
                                </list>
                            </field>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció d'Assignatures -->
    <record model="ir.actions.act_window" id="school_subject_action">
    <field name="name">Subjects</field>
    <field name="res_model">school.subject</field>
    <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu de d'Assignatures -->
    <menuitem name="Subjects" id="menu_subjects" parent="menu_configuration" action="school_subject_action"/>


    <!-- GESTIÓ DE PROFESSORS -->
    
    <!-- Vista Llista de Professors -->
    <record model="ir.ui.view" id="school_teacher_list">
        <field name="name">school.teacher.list</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <!-- El decoration serveix per pintar el registre segons una condició -->
            <list string="Teachers" decoration-danger="active==False" decoration-success="active==True">
                <!-- <field name="first_name"></field>
                <field name="last_name"></field> -->
                <!-- Canviem pel camp calculat display_name -->
                <field name="display_name" string="Full Name"></field>
                <field name="birthdate"></field>
                <field name="tin"></field>
                <field name="gender"></field>
                <field name="salary"></field>
                <field name="email"></field>
                <field name="phone"></field>
                <!-- Camps comptadors -->
                <field name="course_count"/>
                <field name="subject_count"/>
                <field name="teaching_count"/>
                <!-- Amb el One2Many, podem veure els cursos de cada Professor afegint el field -->
                <field name="course_ids" optional="hide"></field> <!-- Camp que podem veure anant als 3 punts de la dreta -->
                <!-- Hem de posar el camp active perque l'estem usant en el decoration -->
                <field name="active" column_invisible="1"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari de Professors -->
    <record model="ir.ui.view" id="school_teacher_form">
        <field name="name">school.teacher.form</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <!-- Per posar una imatge, fem fields.Binary i posem el widget="image" -->
                    <field name="photo" widget="image" class="oe_avatar" nolabel="1"></field>

                    <group> <!-- col = "4" -->
                        <group string="Personal data" col="8">
                            <!-- Si no posem colspan="8", només agafaria "2", valor per defecte -->
                            <field name="first_name" colspan="8" placeholder="???"></field>
                            <field name="last_name" colspan="8" placeholder="???"></field>
                            <field name="birthdate" colspan="4" placeholder="???"></field>
                            <field name="age" colspan="4" placeholder="???"></field>
                            <field name="gender" colspan="3" placeholder="???"></field>
                        </group>

                        <group string="Other data" col="4">
                            <field name="email" widget="email" colspan="4" placeholder="???"></field>
                            <!-- No l'hi hem posat res, colspan="2" PER DEFECTE -->
                            <field name="phone" placeholder="???"></field>
                            <field name="country_id" placeholder="???"></field>
                            <field name="tin" placeholder="???" required="True"></field>
                            <field name="salary" placeholder="???"></field>
                        </group>

                        <!-- Posem el Notebook per a crear una llista de pestanyes -->
                        <notebook>
                            <!-- Nom de la pàgina / nom que sortirà a la pestanya-->
                            <page name="Courses" string="Courses Managed">
                                <group> <!-- Aquest grup ocupa les 4 columnes de la pantalla-->
                                    <group> <!-- Aquest grup ocupa 2 columnes de les 4 => Mitja pantalla -->
                                        <!-- El nolabel="1" serveix per treure l'etiqueta del camp (course_ids) -->
                                        <!-- El widget="many2many" serveix per a que no es borri del tot el curs, només el treiem del professor -->
                                        <field name="course_ids" nolabel="1" readonly="0" widget="many2many" context="{'default_manager_id':id}"> <!-- Fem que no sigui readonly NOMÉS en aquest formulari -->
                                            <!-- Per veure NOMÉS els camps que volguem i en l'ordre que volguem, -->
                                            <!-- fem una list i posem els camps a plaer. -->
                                            <list>
                                                <field name="name"></field>
                                                <field name="hours"></field>
                                            </list>

                                            <!-- Si volem invocar un formulari custom per a l'inserció d'un curs -->
                                            <form>
                                                <group>
                                                    <field name="name"></field>
                                                    <field name="hours"></field>
                                                </group>
                                            </form>
                                        </field>
                                    </group>
                                </group>
                            </page>

                            <page name="Subjects" string="Subjects Authorized">
                                <group> <!-- Aquest grup ocupa les 4 columnes de la pantalla-->
                                    <group> <!-- Aquest grup ocupa 2 columnes de les 4 => Mitja pantalla -->
                                        <field name="subject_ids" nolabel="1" readonly="0">
                                            <list create="0" delete="0"> <!-- create i delete serveixen per amagar les creus o "Nou"-->
                                                <field name="name"></field>
                                                <field name="hours"></field>
                                            </list>
                                        </field>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció de Professors -->
    <record model="ir.actions.act_window" id="school_teacher_action">
        <field name="name">Teachers</field>
        <field name="res_model">school.teacher</field>
        <field name="view_mode">list,form</field>
        <!-- Desactivem el camp active per a que surtin tots els professors, encara que estiguin arxivats o desactivats -->
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- Submenu de Professors -->
    <menuitem name="Teachers" id="menu_teachers" parent="menu_root" sequence="50" action="school_teacher_action"/>


    <!-- GESTIÓ DE TEMÀTIQUES -->
    
    <!-- Vista Llista de Temàtiques -->
     <record model="ir.ui.view" id="school_thematic_list">
        <field name="name">school.thematic.list</field>
        <field name="model">school.thematic</field>
        <field name="arch" type="xml">
            <list string="Thematics">
                <field name="name"></field>
                <field name="parent_id"></field>
                <field name="child_ids"></field>
                <field name="course_ids"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari de Temàtiques -->
     <record model="ir.ui.view" id="school_thematic_form">
        <field name="name">school.thematic.form</field>
        <field name="model">school.thematic</field>
        <field name="arch" type="xml">
            <form string="Thematic">
                <sheet>
                    <group colspan="4">
                        <field name="name"></field>
                        <field name="parent_id"></field>
                    </group>

                    <group colspan="4">
                        <group string="Child Thematics">
                            <field name="child_ids" nolabel="1" colspan="2">
                                <list>
                                    <field name="name"></field>
                                </list>
                            </field>
                        </group>

                        <group string="Courses">
                            <field name="course_ids" nolabel="1" colspan="2">
                                <list>
                                    <field name="name"></field>
                                    <field name="hours"></field>
                                    <field name="manager_id"></field>
                                </list>
                            </field>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció de Temàtiques -->
     <record model="ir.actions.act_window" id="school_thematic_action">
        <field name="name">Thematics</field>
        <field name="res_model">school.thematic</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu de Temàtiques -->
     <menuitem name="Thematics" id="menu_thematics" parent="menu_configuration" sequence="50" action="school_thematic_action"/>


    
    <!-- GESTIÓ DE TEACHING -->
    
    <!-- Vista Llista de Teaching -->
     <record model="ir.ui.view" id="school_teaching_list">
        <field name="name">school.teaching.list</field>
        <field name="model">school.teaching</field>
        <field name="arch" type="xml">
            <list string="Teaching" editable="top">
                <field name="edition_id" readonly="subject_id != False"/>

                <field name="subject_id" 
                       domain="[('course_id', '=', edition_course_id)]"
                       readonly="edition_id == False or teacher_id != False"/>

                <field name="teacher_id"
                       domain="[('id', 'in', subject_teacher_ids)]"
                       readonly="subject_id == False"/>
            </list>
        </field>
    </record>

    <!-- Acció de Teaching -->
     <record model="ir.actions.act_window" id="school_teaching_action">
        <field name="name">Teaching</field>
        <field name="res_model">school.teaching</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Submenu de Teaching -->
     <menuitem name="Teaching" id="menu_teaching" parent="menu_root" sequence="75" action="school_teaching_action"/>
    

    
    <!-- GESTIÓ DE COURSEEDITION -->
    
    <!-- Vista Calendar de CourseEdition -->
    <record model="ir.ui.view" id="school_course_edition_calendar">
        <field name="name">school.course.edition.calendar</field>
        <field name="model">school.course.edition</field>
        <field name="arch" type="xml">
            <calendar date_start="date_start" mode="month">
                <field name="course_id"/>
                <field name="name"/>
                <field name="date_end"/>
            </calendar>
        </field>
    </record>

    <!-- Acció de CourseEdition -->
    <record model="ir.actions.act_window" id="school_course_edition_action">
        <field name="name">Course Editions</field>
        <field name="res_model">school.course.edition</field>
        <field name="view_mode">calendar</field>
    </record>

    <!-- Submenu de CourseEdition -->
     <menuitem name="Course Editions" id="menu_course_edition" parent="menu_configuration" sequence="20" action="school_course_edition_action"/>
    
</odoo>